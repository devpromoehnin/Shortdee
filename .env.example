# ─────────────────────────────────────────────────────────────
# ClipDee — Environment Variables
# Copy to .env.local and fill in. NEVER commit real secrets.
# ─────────────────────────────────────────────────────────────

# ── General ──
NODE_ENV=development

# ── Supabase (Database + Auth) ── [Phase 2 — required]
# Project Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Connection strings — Project Settings → Database → Connection string.
# DATABASE_URL: Transaction pooler (port 6543) — used by the app at runtime.
DATABASE_URL=postgresql://postgres.your-project:[password]@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true
# DIRECT_URL: Session pooler (port 5432) — used by Prisma Migrate for DDL.
DIRECT_URL=postgresql://postgres.your-project:[password]@aws-0-<region>.pooler.supabase.com:5432/postgres

# ── Frontend (apps/web) ──
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
NEXT_PUBLIC_API_URL=http://localhost:3001

# ── API Gateway (apps/api) ──
API_PORT=3001
API_HOST=0.0.0.0
WEB_ORIGIN=http://localhost:3000
AI_SERVICE_URL=http://localhost:8000

# ── AI Service (apps/ai) ── [Phase 4]
AI_PORT=8000
# Google AI Studio → Get API key
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash
# Optional fallback
OPENAI_API_KEY=
WHISPER_MODEL=large-v3

# ── Redis / Queue (BullMQ) ── [Phase 3]
# Local dev: redis://localhost:6379 (see infra/docker-compose.yml)
# Prod: Upstash connection string
REDIS_URL=redis://localhost:6379

# ── Cloudflare R2 (Object Storage) ── [Phase 3]
# Cloudflare Dashboard → R2 → Manage API Tokens
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_UPLOADS=clipdee-uploads
R2_BUCKET_CLIPS=clipdee-clips
R2_PUBLIC_URL=

# ── TikTok Publishing ── [Phase 7]
# developers.tiktok.com → your app → Client Key / Secret
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=

# ── Omise (Payment — Thailand) ── [Phase 8]
OMISE_PUBLIC_KEY=
OMISE_SECRET_KEY=

# ── Monitoring ── [optional]
SENTRY_DSN=
